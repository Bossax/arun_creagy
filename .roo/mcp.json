{
	"mcpServers": {
		"oracle-v2": {
			"command": "bun",
			"args": [
				"run",
				"src/index.ts"
			],
			"cwd": "c:/Users/sitth/ghq/github.com/Soul-Brews-Studio/oracle-v2",
			"env": {},
			"alwaysAllow": [
				"oracle_learn",
				"oracle_handoff",
				"oracle_search",
				"oracle_reflect",
				"oracle_concepts",
				"____IMPORTANT",
				"oracle_list",
				"oracle_stats",
				"oracle_trace",
				"oracle_supersede",
				"oracle_inbox"
			]
		},
		"notebooklm": {
			"command": "npx",
			"args": [
				"-y",
				"notebooklm-mcp@latest"
			],
			"env": {
				"BROWSER_TIMEOUT": "180000",
				"STEALTH_ENABLED": "false",
				"TYPING_WPM_MIN": "400"
			},
			"alwaysAllow": [
				"ask_question",
				"get_health",
				"cleanup_data"
			]
		}
	}
}